<?xml version="1.0" ?>
<!--
  ===================================================================
  VBot 导航训练场景 — Section011 + Section012 合并地形
  ===================================================================
  
  赛道布局（Y轴为前进方向）：
  
    Y ≈ -5  ┌──────────────────┐  赛道起点（机器人出生区域）
            │   Section 011    │  楼梯/平台地形（0126_C_section01）
            │  台阶、斜坡、     │  视觉模型：0202_V_section01
            │  "2026"平台等     │
    Y ≈ 8   ├──────────────────┤  Section011 → Section012 过渡
            │   Section 012    │  复杂地形（0131_C_section02_hotfix1_fullmap）
            │  崎岖地面、坡道、 │  视觉模型：0202_V_section02
            │  丙午大吉平台等   │  使用 fullmap 版本避免 heightfield 冲突
    Y ≈ 24  └──────────────────┘  终点：丙午大吉平台
  
  文件组织：
    - V 后缀 = Visual（视觉渲染模型，不参与物理碰撞）
    - C 后缀 = Collision（碰撞模型，参与物理仿真）
    - 前缀 V1_/C1_ = Section011 的命名空间
    - 前缀 V2_/C2_ = Section012 的命名空间
  
  传感器命名规则：
    - _s1 后缀 = 与 Section011 地面 (C1_ground_root) 的接触
    - _s2 后缀 = 与 Section012 地面 (C2_ground_root) 的接触
    - 同一时刻机器人只能站在一段地面上，所以环境代码中
      将 s1+s2 的传感器值求和即可得到实际接触力
  ===================================================================
-->
<mujoco model="vbot navigation - section011+012 combined terrain training">

  <!-- 编译器设置：角度用弧度、网格文件在meshes/子目录、自动推断关节限位 -->
  <compiler angle="radian" meshdir="meshes/" autolimits="true"/>
  
  <!-- 引入 VBot 四足机器人定义（关节、执行器、传感器等） -->
  <include file="vbot.xml" />
  
  <!-- 场景统计参数：影响默认相机视角和缩放 -->
  <!-- center: 相机注视点(0,10,0.1)位于赛道中段 -->
  <!-- extent: 视野范围30m，足以覆盖整条赛道 -->
  <statistic center="0 10 0.1" extent="30" meansize="0.04" />

  <!-- 渲染设置 -->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />          <!-- 远景雾气颜色 -->
    <global azimuth="120" elevation="-20" />   <!-- 默认相机方位角和俯仰角 -->
    <map force="0.01" />                       <!-- 力可视化缩放 -->
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2" /> <!-- 可视化尺度 -->
    <quality shadowsize="8192" />              <!-- 阴影贴图分辨率 -->
  </visual>

  <asset>
    <!-- 天空盒：蓝天渐变到黑色 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    
    <!-- ========== Section011：楼梯/平台地形 ========== -->
    <model name="section011V" file="0202_V_section01.xml"/>  <!-- 视觉模型（仅渲染） -->
    <model name="section011C" file="0126_C_section01.xml"/>  <!-- 碰撞模型（物理交互） -->
    
    <!-- ========== Section012：复杂崎岖地形 ========== -->
    <!-- 使用 fullmap 版本：将 heightfield 预烘焙为多边形网格，
         避免多个 heightfield 在同一场景中冲突 -->
    <model name="section012V" file="0202_V_section02.xml"/>                    <!-- 视觉模型 -->
    <model name="section012C" file="0131_C_section02_hotfix1_fullmap.xml"/>    <!-- 碰撞模型 -->
  </asset>

  <worldbody>
    <!-- 场景主光源：从正上方照射的平行光 -->
    <light pos="0 10 10" dir="0 0 -1" directional="true" />
    
    <!-- ===== 视觉模型挂载（仅用于渲染，不影响物理） ===== -->
    <!-- prefix 确保子模型中的 body/geom 名称不冲突 -->
    <attach model="section011V" prefix="V1_"/>  <!-- Section011 视觉 -->
    <attach model="section012V" prefix="V2_"/>  <!-- Section012 视觉 -->
    
    <!-- ===== 碰撞模型挂载（参与物理仿真） ===== -->
    <!-- 直接挂在 worldbody 下，不需要额外的包裹 body -->
    <attach model="section011C" prefix="C1_"/>  <!-- Section011 碰撞 → 地面根节点: C1_ground_root -->
    <attach model="section012C" prefix="C2_"/>  <!-- Section012 碰撞 → 地面根节点: C2_ground_root -->
  </worldbody>

  <!-- ===== 接触传感器定义 ===== -->
  <!-- 
    每段地面各配一组传感器（4只脚 + 1个基座 = 5个），共10个传感器。
    subtree1: 机器人部件（FR_foot=右前脚, FL_foot=左前脚, RR_foot=右后脚, RL_foot=左后脚, base=基座）
    subtree2: 对应段的地面碰撞体根节点
    data="normal": 返回接触法向力（3维向量）
    num="1": 每次最多返回1个接触点
    
    用途：
    - foot_contact_s1/s2: 检测脚是否踩在地面上（用于步态奖励、崎岖地形观测）
    - base_contact_s1/s2: 检测基座是否碰地（用于摔倒终止判定）
  -->
  <sensor>
    <!-- Section011 地面接触（_s1 后缀） -->
    <contact name="FR_foot_contact_s1" subtree1="FR_foot" subtree2="C1_ground_root" data="normal" num="1" />  <!-- 右前脚 ↔ 011地面 -->
    <contact name="FL_foot_contact_s1" subtree1="FL_foot" subtree2="C1_ground_root" data="normal" num="1" />  <!-- 左前脚 ↔ 011地面 -->
    <contact name="RR_foot_contact_s1" subtree1="RR_foot" subtree2="C1_ground_root" data="normal" num="1" />  <!-- 右后脚 ↔ 011地面 -->
    <contact name="RL_foot_contact_s1" subtree1="RL_foot" subtree2="C1_ground_root" data="normal" num="1" />  <!-- 左后脚 ↔ 011地面 -->
    <contact name="base_contact_s1"    subtree1="base"    subtree2="C1_ground_root" data="normal" num="1" />  <!-- 基座  ↔ 011地面（摔倒检测） -->

    <!-- Section012 地面接触（_s2 后缀） -->
    <contact name="FR_foot_contact_s2" subtree1="FR_foot" subtree2="C2_ground_root" data="normal" num="1" />  <!-- 右前脚 ↔ 012地面 -->
    <contact name="FL_foot_contact_s2" subtree1="FL_foot" subtree2="C2_ground_root" data="normal" num="1" />  <!-- 左前脚 ↔ 012地面 -->
    <contact name="RR_foot_contact_s2" subtree1="RR_foot" subtree2="C2_ground_root" data="normal" num="1" />  <!-- 右后脚 ↔ 012地面 -->
    <contact name="RL_foot_contact_s2" subtree1="RL_foot" subtree2="C2_ground_root" data="normal" num="1" />  <!-- 左后脚 ↔ 012地面 -->
    <contact name="base_contact_s2"    subtree1="base"    subtree2="C2_ground_root" data="normal" num="1" />  <!-- 基座  ↔ 012地面（摔倒检测） -->
  </sensor>

</mujoco>
