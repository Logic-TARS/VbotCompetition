<?xml version="1.0" ?>
<mujoco model="vbot navigation - section01">
  <compiler angle="radian" meshdir="meshes/" autolimits="true"/>
  
  <!-- 引入vbot机器人 -->
  <include file="vbot.xml" />
  
  <statistic center="0 0 0.1" extent="12" meansize="0.04" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="120" elevation="-20" />
    <map force="0.01" />
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2" />
    <quality shadowsize="8192" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    
    <!-- 加载需要的模型 -->
    <model name="section01V" file="0202_V_section01.xml"/>  <!-- 视觉模型 -->
    <model name="section01C" file="0126_C_section01.xml"/>  <!-- 碰撞模型 -->

    <!-- ========== 红包（金球）贴图和材质 ========== -->
    <!-- 复用 section02 的 GoldBall 贴图与材质，与 0303_V_section02.xml 一致 -->
    <texture type="2d" colorspace="sRGB" name="GoldBall_BK_Bake1_CyclesBake S2A_COMBINED"
             file="assets/GoldBall_BK_Bake1_CyclesBake S2A_COMBINED.png"/>
    <material name="MI_GoldBall_BK" rgba="1 1 1 1" reflectance="0.5" metallic="0.0" roughness="0.5">
      <layer texture="GoldBall_BK_Bake1_CyclesBake S2A_COMBINED" role="rgb"/>
    </material>
    <!-- 金球装饰网格（origin-centered, ~4.6×5.4×1.9m） -->
    <mesh name="V_GoldBall_BK" file="../assets/V_GoldBall_BK.obj"/>
  </asset>

  <worldbody>
    <light pos="0 0 10" dir="0 0 -1" directional="true" />
    
    <!-- 直接加载模型，不嵌套在body中 -->
    <attach model="section01V" prefix="V_"/>   <!-- 视觉模型前缀V_ -->
    <attach model="section01C" prefix="C_"/>   <!-- 碰撞模型前缀C_ -->

    <!-- ========== 竞赛元素：笑脸区域标记（坑洼地形，黄色发光球）========== -->
    <!--
      坑洼地形 height field 范围: Y=[-1.5, +1.5], max Z=0.28
      3个笑脸均匀分布在坑洼地形中，Z稍高于地面浮空显示
      位置对应 CompetitionConfig.smiley_positions
    -->
    <body name="smiley_marker_1" pos="0.0 -1.0 0.5">
      <geom type="sphere" size="0.3" rgba="1.0 0.85 0.0 0.8"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.35" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="smiley_marker_2" pos="0.0 0.0 0.5">
      <geom type="sphere" size="0.3" rgba="1.0 0.85 0.0 0.8"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.35" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="smiley_marker_3" pos="0.0 1.0 0.5">
      <geom type="sphere" size="0.3" rgba="1.0 0.85 0.0 0.8"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.35" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>

    <!-- ========== 竞赛元素：红包/金球装饰（斜坡地形）========== -->
    <!--
      斜坡 Adiban_003: Y≈[2.07, 6.89], 坡面从 Z=0 → Z≈1.30 (倾斜15°)
      使用 V_GoldBall_BK 网格（与 0303_V_section02.xml 同款金球贴图）
      放置在斜坡中部，覆盖3个红包触发区域
      位置对应 CompetitionConfig.hongbao_positions: (0,3.0), (0,4.5), (0,6.0)
    -->
    <body name="goldball_decoration" pos="0.0 4.5 0.65">
      <geom type="mesh" mesh="V_GoldBall_BK" material="MI_GoldBall_BK"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    
  </worldbody>

  <sensor>
    <!-- 传感器配置 -->
    <contact name="FR_foot_contact" subtree1="FR_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="FL_foot_contact" subtree1="FL_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="RR_foot_contact" subtree1="RR_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="RL_foot_contact" subtree1="RL_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="base_contact" subtree1="base" subtree2="C_ground_root" data="normal" num="1" />
  </sensor>

</mujoco>