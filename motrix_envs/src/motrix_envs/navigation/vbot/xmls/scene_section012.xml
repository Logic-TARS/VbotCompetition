      <geom type="sphere" size="0.26" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="heli_hongbao_4" pos="0.36 19.79 1.3">
      <geom type="sphere" size="0.2" rgba="1.0 0.85 0.0 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.26" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="heli_hongbao_5" pos="3.49 19.82 1.3">
      <geom type="sphere" size="0.2" rgba="1.0 0.85 0.0 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.26" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>

  </worldbody>

  <sensor>
    <contact name="FR_foot_contact" subtree1="FR_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="FL_foot_contact" subtree1="FL_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="RR_foot_contact" subtree1="RR_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="RL_foot_contact" subtree1="RL_foot" subtree2="C_ground_root" data="normal" num="1" />
    <contact name="base_contact" subtree1="base" subtree2="C_ground_root" data="normal" num="1" />
  </sensor>

</mujoco>