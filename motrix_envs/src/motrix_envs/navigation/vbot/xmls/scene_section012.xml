<?xml version="1.0" ?>
<mujoco model="vbot navigation - section02">
  <compiler angle="radian" meshdir="meshes/" autolimits="true"/>
  
  <!-- 引入vbot机器人 -->
  <include file="vbot.xml" />
  
  <statistic center="0 15 0.1" extent="15" meansize="0.04" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="120" elevation="-20" />
    <map force="0.01" />
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2" />
    <quality shadowsize="8192" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    
    <!-- 加载section02地形模型 - 使用0126版本 -->
    <!-- <model name="section02C" file="0126_C_section02.xml"/> -->
    <model name="section02C" file="0131_C_section02_hotfix1.xml"/> 
    <model name="section02V" file="0202_V_section02.xml"/>  
  </asset>

  <worldbody>
    <light pos="0 15 10" dir="0 0 -1" directional="true" />
    
    <!-- 加载section02地形 -->
    <attach model="section02C" prefix="C_"/>
    <attach model="section02V" prefix="V_"/> 

    <!-- ========== 拜年红包视觉标记（红色发光球，纯视觉无碰撞） ========== -->
    <!-- #1 吊桥桥面: (-3.0, 17.82), 桥面Z≈2.7 → 浮空Z=2.9 -->
    <body name="bainian_hongbao_1" pos="-3.0 17.82 2.9">
      <geom type="sphere" size="0.25" rgba="0.9 0.1 0.1 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.32" rgba="1.0 0.2 0.1 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <!-- #2 吊桥下方: (-2.0, 17.82), 桥底Z≈1.5 -->
    <body name="bainian_hongbao_2" pos="-2.0 17.82 1.5">
      <geom type="sphere" size="0.25" rgba="0.9 0.1 0.1 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.32" rgba="1.0 0.2 0.1 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>

    <!-- ========== 贺礼红包视觉标记（金色发光球，纯视觉无碰撞） ========== -->
    <!-- 5个贺礼红包在河床石头上 -->
