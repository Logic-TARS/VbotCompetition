      <geom type="sphere" size="0.2" rgba="1.0 0.85 0.0 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.26" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="heli_hongbao_2" pos="3.50 16.28 1.3">
      <geom type="sphere" size="0.2" rgba="1.0 0.85 0.0 0.9"
            contype="0" conaffinity="0" group="2" density="0"/>
      <geom type="sphere" size="0.26" rgba="1.0 0.9 0.2 0.3"
            contype="0" conaffinity="0" group="2" density="0"/>
    </body>
    <body name="heli_hongbao_3" pos="2.00 18.10 1.3">
      <geom type="sphere" size="0.2" rgba="1.0 0.85 0.0 0.9"
