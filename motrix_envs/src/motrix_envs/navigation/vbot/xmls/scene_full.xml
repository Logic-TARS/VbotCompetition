<?xml version="1.0" ?>
<mujoco model="vbot navigation - full course (section011+012+013) unified sensors">
  <compiler angle="radian" meshdir="meshes/" autolimits="true"/>
  
  <!-- 引入vbot机器人 -->
  <include file="vbot.xml" />
  
  <!-- 覆盖整个三阶段场景的范围 -->
  <statistic center="0 15 0.1" extent="50" meansize="0.04" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="120" elevation="-20" />
    <map force="0.01" />
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2" />
    <quality shadowsize="8192" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    
    <!-- Section011 (第一阶段) -->
    <model name="section011V" file="0202_V_section01.xml"/>
    <model name="section011C" file="0126_C_section01.xml"/>
    
    <!-- Section012 (第二阶段) - 使用fullmap版本避免heightfield冲突 -->
    <model name="section012V" file="0202_V_section02.xml"/>
    <model name="section012C" file="0131_C_section02_hotfix1_fullmap.xml"/>
    
    <!-- Section013 (第三阶段) -->
    <model name="section013V" file="0202_V_section03.xml"/>
    <model name="section013C" file="0126_C_section03.xml"/>
  </asset>

  <worldbody>
    <light pos="0 15 10" dir="0 0 -1" directional="true" />
    
    <!-- 视觉模型（带前缀，不影响传感器） -->
    <attach model="section011V" prefix="V1_"/>
    <attach model="section012V" prefix="V2_"/>
    <attach model="section013V" prefix="V3_"/>
    
    <!-- 碰撞模型直接挂在worldbody下（不使用wrapper body） -->
    <!-- motrixsim的subtree传感器无法穿透wrapper body检测子body的碰撞 -->
    <attach model="section011C" prefix="C1_"/>
    <attach model="section012C" prefix="C2_"/>
    <attach model="section013C" prefix="C3_"/>
  </worldbody>

  <sensor>
    <!-- 每个阶段地面独立传感器（motrixsim不支持多subtree合并） -->
    <!-- Section 1 -->
    <contact name="FR_foot_contact_s1" subtree1="FR_foot" subtree2="C1_ground_root" data="normal" num="1" />
    <contact name="FL_foot_contact_s1" subtree1="FL_foot" subtree2="C1_ground_root" data="normal" num="1" />
    <contact name="RR_foot_contact_s1" subtree1="RR_foot" subtree2="C1_ground_root" data="normal" num="1" />
    <contact name="RL_foot_contact_s1" subtree1="RL_foot" subtree2="C1_ground_root" data="normal" num="1" />
    <contact name="base_contact_s1"    subtree1="base"    subtree2="C1_ground_root" data="normal" num="1" />
    <!-- Section 2 -->
    <contact name="FR_foot_contact_s2" subtree1="FR_foot" subtree2="C2_ground_root" data="normal" num="1" />
    <contact name="FL_foot_contact_s2" subtree1="FL_foot" subtree2="C2_ground_root" data="normal" num="1" />
    <contact name="RR_foot_contact_s2" subtree1="RR_foot" subtree2="C2_ground_root" data="normal" num="1" />
    <contact name="RL_foot_contact_s2" subtree1="RL_foot" subtree2="C2_ground_root" data="normal" num="1" />
    <contact name="base_contact_s2"    subtree1="base"    subtree2="C2_ground_root" data="normal" num="1" />
    <!-- Section 3 -->
    <contact name="FR_foot_contact_s3" subtree1="FR_foot" subtree2="C3_ground_root" data="normal" num="1" />
    <contact name="FL_foot_contact_s3" subtree1="FL_foot" subtree2="C3_ground_root" data="normal" num="1" />
    <contact name="RR_foot_contact_s3" subtree1="RR_foot" subtree2="C3_ground_root" data="normal" num="1" />
    <contact name="RL_foot_contact_s3" subtree1="RL_foot" subtree2="C3_ground_root" data="normal" num="1" />
    <contact name="base_contact_s3"    subtree1="base"    subtree2="C3_ground_root" data="normal" num="1" />
  </sensor>

</mujoco>
